# ─── VWA Caddy reverse proxy ──────────────────────────────────────────────────
# HTTPS with a real domain. Caddy automatically obtains & renews a Let's Encrypt
# TLS certificate for the hostname(s) below.
#
# Requirements:
#   • DNS A-record for pdf-cropper.site  → this server's public IP (65.0.179.69)
#   • DNS A-record for www.pdf-cropper.site → same IP  (optional, redirected)
#   • EC2 security group: ports 80 AND 443 open to 0.0.0.0/0
#
# Port 80 must stay open — Caddy uses it for the ACME HTTP challenge and to
# redirect http→https. Nothing about the app's branding or routing changes;
# only the hostname is set so TLS can be issued.
# ─────────────────────────────────────────────────────────────────────────────

{
    # Global options
    # Uncomment to disable admin API (not needed in production):
    # admin off
}

# Redirect www → apex (keeps a single canonical host)
www.pdf-cropper.site {
    redir https://pdf-cropper.site{uri} permanent
}

pdf-cropper.site {
    # ── Backend API ───────────────────────────────────────────────────────────
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /health* {
        reverse_proxy backend:8000
    }

    # ── Frontend (Next.js) ────────────────────────────────────────────────────
    handle {
        reverse_proxy frontend:3000
    }
}
