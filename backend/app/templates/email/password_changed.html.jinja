{% extends "base.html.jinja" %}
{% block content %}
<h1 style="margin:0 0 16px; font-size:20px; color:#111827;">Your password was changed</h1>
<p style="margin:0; font-size:14px; color:#374151; line-height:1.6;">
  {% if name %}Hi {{ name }},{% endif %} this is a confirmation that your ClearFrame account password was just changed. All other devices have been signed out.
  If you didn't make this change, reset your password immediately and contact support.
</p>
{% endblock %}
