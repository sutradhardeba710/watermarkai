{% extends "base.html.jinja" %}
{% block content %}
<h1 style="margin:0 0 16px; font-size:20px; color:#111827;">Welcome to ClearFrame{% if name %}, {{ name }}{% endif %}</h1>
<p style="margin:0 0 16px; font-size:14px; color:#374151; line-height:1.6;">
  Thanks for signing up. Confirm your email address to start uploading and processing videos.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px 0;">
  <tr>
    <td style="border-radius:8px; background-color:#2563eb;">
      <a href="{{ verify_url }}" style="display:inline-block; padding:12px 24px; font-size:14px; font-weight:600; color:#ffffff; text-decoration:none; border-radius:8px;">Verify your email</a>
    </td>
  </tr>
</table>
<p style="margin:0; font-size:12px; color:#6b7280; line-height:1.6;">
  Or paste this link into your browser:<br>
  <a href="{{ verify_url }}" style="color:#2563eb; word-break:break-all;">{{ verify_url }}</a>
</p>
{% endblock %}
