# AI Video Watermark Detection & Removal System — backend env
# Copy to .env and adjust. All vars prefixed VWA_.

# --- App ---
VWA_ENVIRONMENT=dev
VWA_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
VWA_ACCESS_TOKEN_EXPIRE_MINUTES=30
VWA_REFRESH_TOKEN_EXPIRE_DAYS=14
VWA_CORS_ORIGINS=["http://localhost:3000"]
VWA_APP_BASE_URL=http://localhost:3000

# --- Google Sign-In ---
# Create an OAuth 2.0 Client ID (Web application) at
# https://console.cloud.google.com/apis/credentials, add http://localhost:3000
# (and your prod origin) under "Authorized JavaScript origins", then paste the
# Client ID below. Leave blank to keep Google sign-in disabled.
VWA_GOOGLE_CLIENT_ID=

# --- Database ---
VWA_DATABASE_URL=postgresql+psycopg://vwa:vwa@localhost:5432/vwa

# --- Redis / Celery ---
VWA_REDIS_URL=redis://localhost:6379/0
VWA_CELERY_BROKER_URL=redis://localhost:6379/1
VWA_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Storage: local (default, no Docker) or minio ---
VWA_STORAGE_BACKEND=local
VWA_STORAGE_LOCAL_ROOT=./.storage
# VWA_STORAGE_BACKEND=minio
VWA_MINIO_ENDPOINT=localhost:9000
VWA_MINIO_ACCESS_KEY=minioadmin
VWA_MINIO_SECRET_KEY=minioadmin
VWA_MINIO_SECURE=false
VWA_MINIO_BUCKET_PREFIX=vwa-

# --- Upload limits (SRS UPLOAD-003) ---
VWA_MAX_FILE_SIZE_MB=500
VWA_MAX_DURATION_SECONDS=300
VWA_MAX_WIDTH=1920
VWA_MAX_HEIGHT=1080
VWA_MAX_FPS=60

# --- Retention (SRS STORAGE-006) ---
VWA_RETAIN_ORIGINAL_HOURS=24
VWA_RETAIN_PREVIEW_HOURS=24
VWA_RETAIN_OUTPUT_DAYS=7
VWA_RETAIN_FAILED_HOURS=6

# --- Signed URL ---
VWA_SIGNED_URL_EXPIRE_MINUTES=30

# --- Worker ---
VWA_JOB_TIMEOUT_SECONDS=1800
VWA_MAX_RETRIES=2
VWA_WORKER_CONCURRENCY=2

# --- Email ---
# true: emails are printed to the console/log instead of sent (dev default).
# false: real SMTP delivery via the settings below.
VWA_SMTP_CONSOLE=true
# Gmail SMTP relay. Requires 2-Step Verification enabled on the Google account,
# then an App Password generated at: Google Account > Security > App Passwords
# > "Mail". Use that 16-character App Password below — NOT your normal Google
# account password (Gmail rejects/blocks that over SMTP).
VWA_SMTP_HOST=smtp.gmail.com
VWA_SMTP_PORT=587
VWA_SMTP_USER=your-address@gmail.com
VWA_SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# Gmail requires the From address to match the authenticated account.
VWA_SMTP_FROM=your-address@gmail.com

# --- FFmpeg ---
VWA_FFPROBE_BIN=ffprobe
VWA_FFMPEG_BIN=ffmpeg

# --- Detection ---
VWA_DETECTION_SAMPLE_FPS=1.0
VWA_DETECTION_MIN_SAMPLES=10
VWA_DETECTION_MAX_SAMPLES=200
VWA_DETECTION_CONFIDENCE_THRESHOLD=0.25
VWA_YOLO_WEIGHTS=yolov8n-seg.pt
VWA_OCR_PROVIDER=easyocr

# --- Razorpay (Phase 6 billing) ---
# Get these from https://dashboard.razorpay.com/app/keys (test mode)
VWA_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
VWA_RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
# Set this in Razorpay Dashboard > Webhooks > Secret
VWA_RAZORPAY_WEBHOOK_SECRET=
# Create monthly subscription plans in Razorpay Dashboard > Products > Subscriptions > Plans
# Then paste the plan IDs here:
VWA_RAZORPAY_PLAN_ID_STARTER=plan_XXXXXXXXXXXX
VWA_RAZORPAY_PLAN_ID_PRO=plan_XXXXXXXXXXXX
