# AI Video Watermark Detection & Removal System â€” frontend env
# Copy to .env (or .env.local) and adjust.

# Backend API base URL used for server-side rendering fetches. In the browser the
# app is same-origin (next.config.js rewrites /api/* to the backend), so this
# only needs to resolve for server components / route handlers.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Google Sign-In (Google Identity Services) ---
# OAuth 2.0 Client ID (Web application type) from
# https://console.cloud.google.com/apis/credentials. Add every exact browser origin
# under "Authorized JavaScript origins". For local development this usually means
# http://localhost:3000 and, if you use it, http://127.0.0.1:3000. Scheme, host, and
# port must match the address bar. Add the production origin separately. Leave blank to
# hide the "Continue with Google" button on the login/register pages — the
# GIS button renders nothing when this is unset.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
